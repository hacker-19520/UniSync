PORT=3001
JWT_SECRET=unisync-super-secret-key-change-in-production

# Email Configuration (optional - app works in mock mode without these)
# For Gmail: Use App Password from Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=UniSync <noreply@unisync.com>


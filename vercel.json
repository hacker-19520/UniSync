{
  "framework": "vite",
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api(.*)", "destination": "https://unisync-u9dz.onrender.com/api$1" },
    { "source": "/socket.io(.*)", "destination": "https://unisync-u9dz.onrender.com/socket.io$1" }
  ]
}
